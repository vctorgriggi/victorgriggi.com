---
import { SOCIAL_LINKS } from '@/consts';
import LetterGlitch from '@/React/components/LetterGlitch';
import SkillsList from '@/React/components/SkillsList';
import SocialIcons from './SocialIcons.astro';
import TechSkills from './TechSkills.astro';
---

<section class="mt-12 md:mt-0" id="hero">
  <div class="mx-auto max-w-5xl space-y-8 pb-14 md:py-36">
    <div class="space-y-4 text-left">
      <p class="text-md text-(--white-icon) md:text-lg">Sou o Victor.</p>
      <div
        class="flex flex-col space-y-4 md:gap-4 lg:flex-row lg:items-center lg:space-y-0 lg:space-x-8"
      >
        <h1 class="text-5xl leading-none font-medium text-pretty md:text-6xl">
          Desenvolvedor <br /> Frontend
        </h1>
        <p class="text-md text-(--white-icon) md:text-2xl">
          Interfaces são a forma mais direta de um produto se comunicar. Eu
          trabalho para que essa <span class="shiny-sec">comunicação</span> seja clara,
          consistente e funcional.
        </p>
      </div>
      <div class="pt-3 md:pt-6">
        <SocialIcons links={SOCIAL_LINKS} class="size-8" />
      </div>
    </div>
    <TechSkills />
    <div class="flex flex-col items-center gap-8 lg:flex-row">
      <SkillsList client:load />
      <div
        class="flex size-72.5 justify-center pt-3 md:ml-16 md:h-73 md:w-full md:pt-9"
      >
        <LetterGlitch
          client:load
          glitchColors={['#5E4491', '#A476FF', '#241A38']}
          glitchSpeed={33}
          centerVignette={false}
          outerVignette={true}
          smooth={true}
        />
      </div>
    </div>
  </div>
</section>
