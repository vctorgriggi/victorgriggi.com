---
import Link from './Link.astro';

interface Plan {
  name: string;
  description: string;
  price: string;
  features: string[];
  featured?: boolean;
}

const PLANS: Plan[] = [
  {
    name: 'Landing Page',
    description:
      'Página única focada em conversão e apresentação de produto ou serviço.',
    price: 'A partir de R$ 1.500',
    features: [
      'Design de página única',
      'Desenvolvimento responsivo',
      'Otimização on-page básica para buscadores',
      'Integração de formulário',
      'CMS simples para edição de conteúdo (opcional)',
      'Código otimizado para carregamento rápido',
      'Revisões limitadas',
      'Entrega rápida',
    ],
  },
  {
    name: 'Website Institucional',
    description:
      'Website completo para presença online de empresas ou profissionais.',
    price: 'A partir de R$ 3.000',
    featured: true,
    features: [
      'Website multi-páginas',
      'Estrutura de navegação e hierarquia de conteúdo',
      'Desenvolvimento responsivo',
      'CMS estruturado para gerenciamento de conteúdo',
      'Integrações externas conforme necessidade do site',
      'SEO on-page básico',
      'Prazo de entrega maior',
    ],
  },
  {
    name: 'Projeto Sob Medida',
    description:
      'Soluções personalizadas para necessidades específicas, incluindo aplicações web complexas.',
    price: 'Valor sob consulta',
    features: [
      'Desenvolvimento full-stack',
      'Banco de dados',
      'Integrações externas',
      'Foco em performance e segurança',
      'Arquitetura definida conforme o projeto',
      'Revisões conforme escopo',
      'Escopo flexível',
    ],
  },
];
---

<section id="pricing" class="border-t border-[#ffffff10] py-12">
  <div class="mx-auto max-w-5xl">
    <h2 class="shiny-sec mb-2 text-lg">Colaboração</h2>
    <h3 class="mb-8 text-4xl font-medium md:text-5xl">Como Funciona</h3>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        PLANS.map((plan) => (
          <div
            class={[
              'group flex h-full flex-col rounded-2xl bg-[#1414149c] p-8 transition-all duration-300 ease-out',
              plan.featured
                ? 'border-primary border shadow-[0_0_0_1px_var(--primary),0_0_28px_-18px_var(--primary)] hover:shadow-[0_0_0_1px_var(--primary),0_0_44px_-14px_var(--primary)]'
                : 'hover:border-primary border border-(--white-icon-tr) hover:shadow-lg',
              'hover:-translate-y-1',
            ].join(' ')}
          >
            <h4
              class={[
                'text-lg/8 font-semibold',
                plan.featured ? 'text-primary' : 'text-text',
              ].join(' ')}
            >
              {plan.name}
            </h4>
            <p class="mt-3 text-sm text-(--white-icon)">{plan.description}</p>
            <p
              class={[
                'mt-5',
                plan.featured ? 'text-2xl font-medium' : 'text-xl',
              ].join(' ')}
            >
              {plan.price}
            </p>
            <ul class="mt-6 space-y-2 text-sm text-(--white-icon)">
              {plan.features.map((feature) => (
                <li class="flex gap-x-3">
                  <span class="text-primary">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto pt-6">
              <Link
                href="https://cal.com/victor-griggi/30min"
                aria-label="Agendar Conversa"
                title="Agendar Conversa"
                external
                class="flex w-full justify-center"
              >
                Agendar Conversa
              </Link>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
