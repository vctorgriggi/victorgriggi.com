---
import NextSupabaseTemplate from '@/../public/projects/next-supabase-template.png';
import { ICON_MAP } from '@/consts';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import Link from './Link.astro';

interface Project {
  title: string;
  description: string;
  image: ImageMetadata;
  preview: string;
  repo?: string;
}

const PROJECTS: Project[] = [
  {
    title: 'Next Supabase Template',
    description:
      'Production-ready Next.js + Supabase starter with auth, profiles, file uploads, and end-to-end type safety. Opinionated architecture for maintainable apps.',
    image: NextSupabaseTemplate,
    preview: 'https://next-supabase-template-zeta.vercel.app/',
    repo: 'https://github.com/vctorgriggi/next-supabase-template',
  },
];
---

<section id="projects" class="border-t border-[#ffffff10] py-12">
  <div class="mx-auto max-w-5xl">
    <h2 class="shiny-sec mb-2 text-lg">Projetos</h2>
    <h3 class="mb-8 text-4xl font-medium md:text-5xl">Destaques</h3>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        PROJECTS.map((item) => (
          <div class="group">
            <a
              href={item.preview}
              aria-label={item.title}
              title={item.title}
              class="mb-4 block overflow-hidden rounded-2xl border border-(--white-icon-tr) shadow-lg transition-shadow duration-300 hover:shadow-xl"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                src={item.image}
                alt={item.title}
                class="aspect-video w-full object-cover grayscale transition-all duration-300 group-hover:scale-105 group-hover:grayscale-0"
              />
            </a>

            <div class="flex items-start gap-4 px-4">
              <div class="grow">
                <h4 class="text-2xl font-semibold">{item.title}</h4>
                <span class="mt-1 block text-sm text-(--white-icon)">
                  {item.description}
                </span>
              </div>

              <div class="flex gap-2">
                {item.repo && (
                  <Link
                    href={item.repo}
                    aria-label="GitHub"
                    title="Código Fonte"
                    class="rounded-xl"
                    external
                  >
                    <Icon name={ICON_MAP.GitHub} class="size-5" />
                  </Link>
                )}

                <Link
                  href={item.preview}
                  aria-label="Preview"
                  title="Preview"
                  class="rounded-xl"
                  external
                >
                  <Icon name={ICON_MAP.Out} class="size-5" />
                </Link>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-10">
      <Link
        href="https://github.com/vctorgriggi"
        aria-label="GitHub"
        title="GitHub"
        class="inline-flex w-full items-center justify-center gap-1.5"
        external
      >
        Ver mais no GitHub
        <Icon name={ICON_MAP.GitHub} class="size-4" />
      </Link>
    </div>
  </div>
</section>
