---
import { STACK_ICONS } from '@/icons/stack';

interface TechSkill {
  name: string;
  icon: keyof typeof STACK_ICONS;
}

const SKILLS: TechSkill[] = [
  { name: 'React', icon: 'React' },
  { name: 'TypeScript', icon: 'TypeScript' },
  { name: 'Next.js', icon: 'NextJS' },
  { name: 'Astro', icon: 'Astro' },
  { name: 'Node.js', icon: 'NodeJS' },
  { name: 'NestJS', icon: 'NestJS' },
  { name: 'PostgreSQL', icon: 'PostgreSQL' },
  { name: 'MySQL', icon: 'MySQL' },
];
---

<div class="relative overflow-hidden py-8">
  <!-- fade left -->
  <div
    class="from-background pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-linear-to-r to-transparent"
  >
  </div>

  <!-- fade right -->
  <div
    class="from-background pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-linear-to-l to-transparent"
  >
  </div>

  <!-- viewport -->
  <div class="relative w-full">
    <div class="scroll-track flex gap-12 md:gap-20">
      {
        [...SKILLS, ...SKILLS].map((item) => (
          <div class="group flex items-center gap-2">
            <img
              src={STACK_ICONS[item.icon].src}
              alt={item.name}
              class="h-7 w-auto opacity-60 transition-transform duration-300 group-hover:scale-110"
              width="30"
              height="30"
              loading="lazy"
            />
            <span class="text-lg font-medium text-(--white-icon)">
              {item.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .scroll-track {
    width: max-content;
    animation: scroll 45s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-track {
      animation: none;
    }
  }
</style>
